{
  "manifest_version": 3,
  "name": "cnki-PDF-download",
  "version": "1.0",
  "description": "在知网文章列表页面添加直接下载PDF按钮、摘要悬停显示功能和下载所有PDF按钮。",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["https://*.cnki.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.cnki.net/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_title": "cnki-PDF-download",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png"
    }
  }
}
